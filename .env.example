# Railway automatically injects DATABASE_URL for Postgres. For local testing with Postgres, uncomment and set this:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/5letterword

# You must set this in Railway and locally to enable Google Sign-In
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Email reminder configuration (Resend API key and Sender address)
RESEND_API_KEY=re_123456789abc
SENDER_EMAIL=reminders@play.yourdomain.com

# Secret token to protect the cron endpoint (used to authenticate Cron-Job.org requests)
CRON_SECRET=your_secure_cron_secret_token

